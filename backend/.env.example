# =============================================================================
# DES Unified Platform — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (PostgreSQL via Neon) ---
# Full connection string: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# --- JWT Authentication ---
# Long random secret string (min 64 chars) — use: openssl rand -base64 64
JWT_SECRET=
# Token expiry (e.g. 7d, 24h)
JWT_EXPIRES_IN=7d

# --- Redis (Upstash) ---
# Format: redis://default:<password>@<host>:<port>
REDIS_URL=

# --- Cloudflare R2 (S3-compatible file storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Your R2 bucket name
R2_BUCKET_NAME=
# Public CDN URL for your bucket (if public access enabled)
R2_PUBLIC_URL=

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=

# --- CORS ---
# Frontend URL (Vercel URL in production)
CORS_ORIGIN=http://localhost:3000

# --- Logging (Better Stack / Logtail) ---
LOGTAIL_SOURCE_TOKEN=
