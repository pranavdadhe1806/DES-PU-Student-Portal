// Status: Scaffold only — no models yet.
// Models will be added in Week 1 of the build sprint.
// See PLAN.md for full DB design before adding models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon uses connection pooling — use directUrl for migrations
  directUrl = env("DIRECT_DATABASE_URL")
}

