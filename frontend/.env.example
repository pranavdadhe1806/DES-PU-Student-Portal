# =============================================================================
# DES Unified Platform — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# --- Backend API ---
# Base URL of the Express backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000

# --- Socket.io ---
# Same as API URL — Socket.io runs on the same Express server
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# --- Cloudflare R2 Public CDN ---
# Public URL for serving uploaded files (images, PDFs, etc.)
NEXT_PUBLIC_R2_PUBLIC_URL=
